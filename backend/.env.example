# Configuración de correo (Gmail)
# 1) Activa la verificación en dos pasos en tu cuenta de Google.
# 2) Crea una "Contraseña de aplicación".

EMAIL_USER=eliasalfarnate@gmail.com
EMAIL_PASS=PEGA_AQUI_TU_CONTRASEÑA_DE_APLICACION
EMAIL_TO=eliasalfarnate@gmail.com

# (Opcional) anti-spam: minutos mínimos entre alertas repetidas del mismo antibiótico
EMAIL_THROTTLE_MINUTES=20

# (Opcional) ruta de tu base de datos SQLite (si no, usa backend/db2.db o backend/db/local.db)
# SQLITE_PATH=./db/local.db

# Backup automático de SQLite al arrancar (1=SI, 0=NO)
LOCAL_DB_BACKUP=1
